# Neon PostgreSQL connection string (use the pooled connection string if available)
DATABASE_URL="postgresql://username:password@ep-example-000000.region.aws.neon.tech/neondb?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="a-random-32-byte-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Error-only production monitoring (Sentry free tier).
# The DSN is public configuration; keep SENTRY_AUTH_TOKEN secret and use it only
# in CI/Vercel builds for source-map uploads. Tracing, replay, and Sentry logs
# are disabled by the application configuration.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT="builderbridge"
SENTRY_AUTH_TOKEN=""

# OpenRouter (powers the Schedule Q&A Assistant). Get a key at https://openrouter.ai/keys
# Leave OPENROUTER_API_KEY unset to disable the assistant.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openrouter/free"
# Ordered comma-separated fallbacks. openrouter/free is itself a free multi-model router.
OPENROUTER_FALLBACK_MODELS="openrouter/free"
# Retry transient pre-stream failures with exponential backoff (0-5).
OPENROUTER_MAX_RETRIES="2"
# Per-user Agent messages allowed in one minute. Replayed requests are not counted.
AI_CHAT_RATE_LIMIT_PER_MINUTE="30"
# Monthly OpenRouter requests per organization plan. Deterministic project actions are free.
AI_MONTHLY_LIMIT_FREE="250"
AI_MONTHLY_LIMIT_CORE="2500"
AI_MONTHLY_LIMIT_PRO="10000"

# S3-compatible object storage for uploads (Supabase Storage / Cloudflare R2 / AWS S3 / MinIO).
# Leave all unset in dev to fall back to local disk (public/uploads/).
# REQUIRED in production — local-disk uploads don't survive serverless deploys.
# See DEPLOYMENT.md for setup steps.
#
# Supabase example:
#   S3_ENDPOINT="https://<project-ref>.storage.supabase.co/storage/v1/s3"
#   S3_REGION="<project-region>"           # e.g. ap-south-1
# Create the Supabase bucket as PRIVATE. BuilderBridge streams authorized files
# through /api/files; no public URL or browser-side Supabase key is required.
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_REGION="auto"

# Free, self-hosted OCRmyPDF worker for scanned PDFs and images.
# Run `docker compose -f docker-compose.ocr.yml up --build`, then set the same
# token in both the app and worker environments.
OCR_SERVICE_URL="http://localhost:8010"
OCR_SERVICE_TOKEN="replace-with-a-long-random-token"
OCR_SERVICE_TIMEOUT_MS="120000"

# Stripe billing (https://dashboard.stripe.com — use TEST mode keys, no real charges).
# Leave all unset to disable billing: every org stays on the Free plan.
# STRIPE_PRICE_CORE / STRIPE_PRICE_PRO are recurring Price IDs (price_...)
# created in the Stripe dashboard for the Core and Pro subscription products.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_CORE=""
STRIPE_PRICE_PRO=""

# Procore integration (https://developers.procore.com — use Sandbox OAuth credentials).
# Redirect URI in the Procore app settings must match PROCORE_REDIRECT_URI
# (defaults to http://localhost:3000/api/integrations/procore/callback in dev).
PROCORE_CLIENT_ID=""
PROCORE_CLIENT_SECRET=""
PROCORE_REDIRECT_URI=""
PROCORE_ENV="sandbox"

# Autodesk ACC integration (https://aps.autodesk.com — free APS tier).
# Callback URL in your APS app must match AUTODESK_REDIRECT_URI
# (defaults to http://localhost:3000/api/integrations/autodesk/callback in dev).
AUTODESK_CLIENT_ID=""
AUTODESK_CLIENT_SECRET=""
AUTODESK_REDIRECT_URI=""

# Email notifications via Resend (https://resend.com — free tier available).
# Leave RESEND_API_KEY unset to skip sending; the app works normally without it.
# EMAIL_FROM must be a verified-domain sender in production; the resend.dev
# default only delivers to your own Resend account email.
RESEND_API_KEY=""
EMAIL_FROM="BuilderBridge <onboarding@resend.dev>"
